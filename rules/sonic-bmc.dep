SPATH       := $($(SONIC_BMCD)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) rules/sonic-bmc.mk rules/sonic-bmc.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
SMDEP_FILES := $(addprefix $(SPATH)/,$(shell cd $(SPATH) && git ls-files))

$(SONIC_BMCD)_CACHE_MODE  := GIT_CONTENT_SHA
$(SONIC_BMCD)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(SONIC_BMCD)_DEP_FILES   := $(DEP_FILES)
$(SONIC_BMCD)_SMDEP_FILES := $(SMDEP_FILES)
$(SONIC_BMCD)_SMDEP_PATHS := $(SPATH)